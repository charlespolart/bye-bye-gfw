# bye-bye-gfw — config template
# Copy to `config.env` and fill in. config.env is gitignored — keep secrets there.

# === Domain ===
DOMAIN=charlespolart.com
PANEL_SUBDOMAIN=panel
SUB_SUBDOMAIN=sub
HY2_SUBDOMAIN=hy2
CDN_SUBDOMAIN=cdn

# === SSH/system hardening (Phase 1) ===
SSH_PORT=52217
DEPLOY_USER=deploy
# Path to public key file the deploy user will accept.
# Defaults to /root/.ssh/authorized_keys (which provider populated when you uploaded
# your pubkey via the panel). Override only if your pubkey is elsewhere.
DEPLOY_PUBKEY_FILE=/root/.ssh/authorized_keys

# === REALITY (Phase 4) ===
# SNI must be: TLS 1.3 + H2 + non-Cloudflare CDN, low RTT from VPS.
# LAX VPS candidates (in priority): www.tesla.com, swdist.apple.com, gateway.icloud.com,
# www.bing.com, www.microsoft.com.
# DO NOT use lovelive-anime.jp on a US VPS (geo-mismatch suspicious).
# Validate before commit with: xray tls ping <host>
REALITY_SNI=www.tesla.com

# === Hysteria2 bandwidth (Phase 4) ===
# Set to YOUR REAL VPS bandwidth in mbps. Brutal CC throttles if you lie.
# Measure on the VPS with: speedtest-cli --simple
# Will be auto-measured at deploy time if left empty.
HYSTERIA_UP_MBPS=
HYSTERIA_DOWN_MBPS=

# === WARP outbound (Phase 5) ===
# Set to "yes" to install wgcf + WARP outbound for streaming services.
WARP_ENABLE=yes

# === VPS metadata (informational, used for log output and DEPLOYMENT_NOTES.md) ===
VPS_PROVIDER="DMIT"
VPS_PLAN="LAX.AN5.Pro.TINY"
VPS_LOCATION="Los Angeles"
VPS_IPV4=""
VPS_IPV6=""
